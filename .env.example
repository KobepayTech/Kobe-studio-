# ===========================================================================
# kobeAi SaaS — environment configuration
# Copy to .env and fill in. Never commit your real .env.
# ===========================================================================

# --- Core ------------------------------------------------------------------
# Public URL of your deployment (used for Stripe redirects + magic links).
APP_URL=http://localhost:3001

# Turn on SaaS mode in the UI (skips bring-your-own-key, shows credits).
NEXT_PUBLIC_SAAS_MODE=true

# --- Database (Postgres) ---------------------------------------------------
# With docker-compose this is set for you. For a standalone DB, set it here.
DATABASE_URL=postgresql://kobe:kobe@localhost:5432/kobeai?schema=public
POSTGRES_PASSWORD=kobe

# --- Auth.js ---------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
# Optional but recommended behind a proxy:
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic links (SMTP). For dev, docker-compose ships Mailhog:
#   host=mailhog port=1025  (inbox at http://localhost:8025)
# For production use a real provider (Resend, Postmark, SES, ...).
EMAIL_SERVER_HOST=mailhog
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=kobeAi <no-reply@kobe.ai>

# --- MuAPI (the platform's single upstream key) ----------------------------
# This is YOUR MuAPI account key. All user generations are billed through it
# and metered as credits. Get one at https://muapi.ai/access-keys
MUAPI_PLATFORM_KEY=
# MUAPI_BASE=https://api.muapi.ai   # override only if needed

# --- Stripe ----------------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# From `stripe listen` (dev) or the webhook endpoint settings (prod).
STRIPE_WEBHOOK_SECRET=

# Subscription price IDs (create recurring prices in Stripe, paste the price_... ids)
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# One-time credit-pack price IDs (create one-time prices)
STRIPE_PRICE_PACK_SMALL=
STRIPE_PRICE_PACK_MEDIUM=
STRIPE_PRICE_PACK_LARGE=
